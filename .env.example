# ===== APIキーの設定例 =====

# Gemini APIキー（Google AI Studioで取得）
# https://ai.google.dev/
GEMINI_API_KEY=

# NCBI E-utilities（PubMed）APIキー（NCBIアカウントのSettingsで発行）
# https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ===== NCBI 推奨パラメータ（登録推奨） =====
# NCBI側に登録したツール名（半角スペースなし）
NCBI_TOOL=
# 開発者の連絡先メールアドレス（ブロック時の連絡・解除に使用）
NCBI_EMAIL=

# ===== レート制御（任意・クライアント側で使用） =====
# 1秒あたりの最大リクエスト数。APIキーなし: 3、APIキーあり: 10 を目安に設定。
# 実装側でこの値を参照してスロットリングする場合に使用します。
NCBI_RATE_LIMIT_RPS=3
